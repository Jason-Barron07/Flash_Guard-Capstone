{
  "name": "flash-guard-ui-automation",
  "version": "1.0.0",
  "private": true,
  "description": "UI automation package for Flash-Guard.",
  "type": "commonjs",
  "scripts": {
    "test": "playwright test -c playwright.config.ts",
    "test:auth": "playwright test -c playwright.config.ts spec/auth.spec.ts",
    "test:chromium": "playwright test -c playwright.config.ts --project=chromium",
    "test:firefox": "playwright test -c playwright.config.ts --project=firefox",
    "test:report": "playwright show-report artifacts/playwright-report",
    "selectors:codegen": "playwright codegen http://localhost:3000/",
    "lint": "eslint . --ext .ts,.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@playwright/test": "^1.60.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.7.0",
    "dotenv": "^17.2.3",
    "eslint": "^10.3.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.6.0",
    "multiple-cucumber-html-reporter": "^3.9.3",
    "playwright": "^1.60.0",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.59.3"
  }
}
