{
  "name": "flash-guard-mobile-tests",
  "private": true,
  "version": "1.0.0",
  "description": "Playwright + Appium mobile tests for Flash Guard",
  "scripts": {
    "test": "playwright test -c playwright.appium.config.ts",
    "test:auth": "playwright test -c playwright.appium.config.ts specs/auth.spec.ts",
    "test:dashboard": "playwright test -c playwright.appium.config.ts specs/dashboard.spec.ts",
    "test:balance-history": "playwright test -c playwright.appium.config.ts specs/balance-history.spec.ts",
    "test:transfer": "playwright test -c playwright.appium.config.ts specs/transfer.spec.ts",
    "report": "playwright show-report artifacts/playwright-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.16.5",
    "typescript": "^5.8.3",
    "webdriverio": "^9.19.2"
  }
}
