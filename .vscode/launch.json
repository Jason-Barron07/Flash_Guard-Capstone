{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Playwright Debugger",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
            "args": ["test", "--project=chromium"],
            "skipFiles": [ "<node_internals>/**" ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        }
    ]
}